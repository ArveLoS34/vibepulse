{
  "expo": {
    "name": "VibePulse",
    "slug": "vibepulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vibepulse",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "8b323a10-2595-4ef5-923f-vibepulse0001"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.vibepulse.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Profil fotoğraflarınızı ve sohbet içi görsellerinizi yüklemek için erişim izni gereklidir.",
        "NSCameraUsageDescription": "Anlık profil fotoğrafı çekmek için kamera izni gereklidir.",
        "NSLocationWhenInUseUsageDescription": "Yakındaki Vibe kullanıcılarını ve buluşma sinyallerini göstermek için konum izni gereklidir.",
        "NSMicrophoneUsageDescription": "15 saniyelik Voice Vibe ses kaydı göndermek için mikrofon izni gereklidir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0B"
      },
      "edgeToEdgeEnabled": true,
      "package": "app.vibepulse.mobile",
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0B"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğraflarınızı ve Vibe hikayelerinizi yüklemek için galerinizden seçim yapın."
        }
      ],
      "expo-location",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
