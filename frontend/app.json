{
  "expo": {
    "name": "VibePulse",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vibepulse",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.pulseconnect.p5iexe",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload profile photos to show your vibe",
        "NSCameraUsageDescription": "Take a new photo for your profile",
        "NSLocationWhenInUseUsageDescription": "Show nearby vibes and matches"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0B"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.pulseconnect.p5iexe",
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0B"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Upload profile photos to show your vibe"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
